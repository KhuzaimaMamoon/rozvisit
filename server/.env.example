# Runtime
PORT=
NODE_ENV=

# Database
MONGO_URI=

# Auth
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
# Production custom-domain cookie scope (for example, .rozvisit.com)
AUTH_COOKIE_DOMAIN=

# Field encryption
FIELD_ENCRYPTION_KEY=

# Media
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Push
FIREBASE_SERVICE_ACCOUNT_JSON=

# Email
# Gmail SMTP is retained for a future SMTP-capable host. It is never attempted in production on Render.
GMAIL_USER=
GMAIL_APP_PASSWORD=
# Non-production SMTP only: 587 = STARTTLS (default); set 465 for implicit TLS elsewhere.
GMAIL_SMTP_PORT=
# Brevo is the active pilot provider. Use the sender address verified in the Brevo account.
EMAIL_FROM_ADDRESS=
BREVO_API_KEY=
# Dormant fallback reference for a future verified-domain Resend configuration.
RESEND_API_KEY=

# Application
APP_BASE_URL=

# Optional
SENTRY_DSN=
LOG_LEVEL=
# Development only: logs single-use auth links. Never enable outside localhost development.
DEV_LOG_AUTH_LINKS=
