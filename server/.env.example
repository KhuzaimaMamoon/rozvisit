# Runtime
PORT=
NODE_ENV=

# Database
MONGO_URI=

# Auth
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=

# Field encryption
FIELD_ENCRYPTION_KEY=

# Media
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Push
FIREBASE_SERVICE_ACCOUNT_JSON=

# Email (Resend sends real mail only when RESEND_API_KEY is configured)
# Resend's test sender; replace with a verified RozVisit sender before production.
EMAIL_FROM_ADDRESS=onboarding@resend.dev
RESEND_API_KEY=

# Application
APP_BASE_URL=

# Optional
SENTRY_DSN=
LOG_LEVEL=
# Development only: logs single-use auth links. Never enable outside localhost development.
DEV_LOG_AUTH_LINKS=
