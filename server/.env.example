# Runtime
PORT=
NODE_ENV=

# Database
MONGO_URI=

# Auth
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=

# Field encryption
FIELD_ENCRYPTION_KEY=

# Media
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Push
FIREBASE_SERVICE_ACCOUNT_JSON=

# Email
# Gmail SMTP is a temporary bridge for real-user testing. Do not use it for bulk/long-term production sending.
GMAIL_USER=
GMAIL_APP_PASSWORD=
# Resend is the long-term provider once a custom domain sender is verified.
EMAIL_FROM_ADDRESS=onboarding@resend.dev
RESEND_API_KEY=

# Application
APP_BASE_URL=

# Optional
SENTRY_DSN=
LOG_LEVEL=
# Development only: logs single-use auth links. Never enable outside localhost development.
DEV_LOG_AUTH_LINKS=
