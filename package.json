{
  "name": "rozvisit",
  "private": true,
  "type": "module",
  "workspaces": [
    "client",
    "server"
  ],
  "engines": {
    "node": "20.x"
  },
  "scripts": {
    "dev": "npm run dev -w server & npm run dev -w client",
    "build": "npm run build -w client",
    "test": "npm run test -w server",
    "test:e2e": "playwright test",
    "seed": "DOTENV_CONFIG_PATH=server/.env node scripts/seed.js",
    "reset:non-admin-data": "DOTENV_CONFIG_PATH=server/.env node scripts/reset-non-admin-data.js",
    "create:admin": "DOTENV_CONFIG_PATH=server/.env node scripts/create-admin.js",
    "delete:admin": "DOTENV_CONFIG_PATH=server/.env node scripts/delete-admin.js",
    "grant:admin-directory-permissions": "DOTENV_CONFIG_PATH=server/.env node scripts/grant-admin-directory-permissions.js",
    "lint": "oxlint client server",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check:bundle": "node scripts/check-bundle-budget.js"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "oxlint": "*",
    "prettier": "*"
  }
}
